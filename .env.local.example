# Copy this file to .env.local and fill in your values

# OpenWeatherMap API key (get one free at openweathermap.org)
NEXT_PUBLIC_WEATHER_API_KEY=your_api_key_here

# Your city name and country code (e.g. Madrid,ES or London,GB)
NEXT_PUBLIC_WEATHER_CITY=Madrid,ES

# Server host (default: 0.0.0.0 — listens on all interfaces so the Raspberry Pi is reachable from LAN)
HOST=0.0.0.0
PORT=3000
